{
  "name": "note-me",
  "private": true,
  "version": "2.4.0-develop.3",
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "dev": "vite dev",
    "prebuild": "npm run semantic-release:dry",
    "build": "vite build",
    "preview": "vite preview",
    "pwa": "npm run build && npm run preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "type": "npm run check",
    "test": "start-server-and-test dev http://localhost:5173 test:e2e",
    "test:e2e": "cypress run",
    "test:open": "cypress open",
    "semantic-release:dry": "semantic-release --dry-run --no-ci",
    "outdated": "npx npm-check-updates",
    "outdated:minor": "npx npm-check-updates -t minor",
    "update": "npm run outdated -- -u",
    "update:minor": "npm run outdated:minor -- -u"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@sveltejs/adapter-netlify": "^5.2.4",
    "@sveltejs/kit": "^2.48.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vite-pwa/sveltekit": "^1.0.1",
    "bits-ui": "^2.14.3",
    "cypress": "^15.6.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.0",
    "globals": "^16.5.0",
    "idb": "^8.0.3",
    "lucide-svelte": "^0.554.0",
    "marked": "^17.0.0",
    "melt": "^0.41.0",
    "semantic-release": "^25.0.2",
    "start-server-and-test": "^2.1.2",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.17",
    "tailwindcss-safe-area": "^1.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite": "^7.2.2"
  }
}
