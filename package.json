{
  "name": "note-me",
  "private": true,
  "version": "2.6.0-develop.3",
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "pwa": "npm run build && npm run preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "type": "npm run check",
    "test": "start-server-and-test dev http://localhost:5173 test:e2e",
    "test:e2e": "cypress run",
    "test:open": "cypress open",
    "semantic-release:dry": "semantic-release --dry-run --no-ci",
    "outdated": "npx npm-check-updates",
    "outdated:minor": "npx npm-check-updates -t minor",
    "update": "npm run outdated -- -u",
    "update:minor": "npm run outdated:minor -- -u"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.7.0",
    "@sveltejs/adapter-netlify": "^5.2.4",
    "@sveltejs/kit": "^2.50.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.9",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vite-pwa/sveltekit": "^1.1.0",
    "bits-ui": "^2.15.4",
    "cypress": "^15.9.0",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.0.0",
    "idb": "^8.0.3",
    "lucide-svelte": "^0.562.0",
    "marked": "^17.0.1",
    "melt": "^0.44.0",
    "semantic-release": "^25.0.2",
    "start-server-and-test": "^2.1.3",
    "svelte": "^5.47.1",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^4.1.18",
    "tailwindcss-safe-area": "^1.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1"
  }
}
