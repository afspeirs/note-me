{
  "name": "note-me",
  "private": true,
  "version": "2.6.0-develop.13",
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "pwa": "npm run build && npm run preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "type": "npm run check",
    "test": "start-server-and-test dev http://localhost:5173 test:e2e",
    "test:e2e": "cypress run",
    "test:open": "cypress open",
    "semantic-release:dry": "semantic-release --dry-run --no-ci",
    "outdated": "npx npm-check-updates",
    "outdated:minor": "npx npm-check-updates -t minor",
    "update": "npm run outdated -- -u",
    "update:minor": "npm run outdated:minor -- -u"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.5",
    "@lucide/svelte": "^1.24.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@sveltejs/adapter-netlify": "^5.2.4",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.5",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vite-pwa/sveltekit": "^1.1.0",
    "bits-ui": "^2.18.1",
    "cypress": "^15.18.1",
    "eslint": "^9.39.5",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "idb": "^8.0.3",
    "marked": "^17.0.6",
    "melt": "^0.44.0",
    "semantic-release": "^25.0.7",
    "start-server-and-test": "^2.1.5",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "tailwindcss-safe-area": "^1.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6"
  }
}
